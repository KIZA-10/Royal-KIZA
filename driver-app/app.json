{
  "expo": {
    "name": "KIZA Livreur",
    "slug": "kiza-livreur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kiza-livreur",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kiza.livreur",
      "infoPlist": {
        "NSCameraUsageDescription": "Scanner les QR codes des commandes",
        "NSLocationWhenInUseUsageDescription": "Partager votre position pour le suivi des livraisons",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Suivi GPS continu pendant les livraisons"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.kiza.livreur",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Scanner les QR codes"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Suivi GPS pour les livraisons"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "de955451-d77a-4842-bb64-6b890b782fc3"
      }
    },
    "owner": "royalekiza"
  }
}
